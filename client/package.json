{
  "name": "@typeshift/client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "clean:next": "node scripts/clean-next.mjs",
    "clean:worker": "node scripts/clean-worker.mjs",
    "prebuild": "npm run clean:next",
    "build": "next build",
    "prebuild:worker": "npm run clean:worker",
    "build:worker": "opennextjs-cloudflare build --config wrangler.jsonc",
    "predeploy:worker": "npm run clean:worker",
    "deploy:worker": "opennextjs-cloudflare build --config wrangler.jsonc && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "prepreview:worker": "npm run clean:worker",
    "preview:worker": "opennextjs-cloudflare build --config wrangler.jsonc && wrangler dev --config wrangler.jsonc",
    "start": "next start",
    "test": "tsx --test src/**/*.test.ts && tsc -p tsconfig.json --noEmit",
    "preview": "next start"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.3",
    "@types/node": "^24.6.0"
  }
}
