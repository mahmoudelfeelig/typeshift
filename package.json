{
  "name": "typeshift-platform",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm --prefix client run build:worker",
    "build:client": "npm --prefix client run build:worker",
    "test": "npm --prefix client run test",
    "test:e2e": "npx playwright test",
    "preview:worker": "npm --prefix client run preview:worker",
    "deploy:worker": "npm --prefix client run deploy:worker",
    "backup:db": "bash ./scripts/backup-db.sh",
    "restore:db": "bash ./scripts/restore-db.sh",
    "restore:drill": "bash ./scripts/restore-drill.sh",
    "seed:bots": "node scripts/seed-bots.mjs",
    "smoke:check": "bash ./scripts/smoke-check.sh",
    "start": "node scripts/start.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  }
}
